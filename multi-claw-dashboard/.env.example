# MultiClaw Dashboard Configuration
PORT=3100
HOST=0.0.0.0

# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h
DB_PATH=./data/multiclaw.db

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3100

# Admin account (seeds first user on startup if no users exist)
ADMIN_EMAIL=admin@multiclaw.dev
ADMIN_PASSWORD=

# AI Provider Keys (synced to all connected agents)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=

# TLS (recommended for production)
TLS_CERT=
TLS_KEY=

# Tailscale (optional)
MULTICLAW_TAILSCALE_ENABLED=false
MULTICLAW_TAILSCALE_MODE=dual-stack
MULTICLAW_TAILSCALE_TAG=tag:multiclaw-dashboard
